# Copy to .env.local for local dev (never commit secrets)

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase Storage bucket name (create in Dashboard → Storage)
VITE_SUPABASE_STORAGE_BUCKET=food-media

# Nén ảnh sau crop (browser-image-compression)
VITE_IMAGE_MAX_SIZE=1920
VITE_IMAGE_MAX_MB=0.5
VITE_IMAGE_JPEG_QUALITY=0.82

# AI provider: "openai" | "gemini"
VITE_AI_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...
VITE_OPENAI_MODEL=gpt-4o-mini

# Google Gemini — https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash
